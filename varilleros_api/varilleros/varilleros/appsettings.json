{
  "ConnectionStrings": {
    "MasterDb": "Server=localhost;Port=3306;Database=varilleros_master;User=root;Password=1234;CharSet=utf8mb4;"
  },
  "TenantCache": {
    "TtlSeconds": 300
  },
  "Jwt": {
    "Secret": "varilleros-jwt-secret-key-minimo-32-caracteres-CAMBIA-EN-PROD",
    "ExpiryHours": "8",
    "Issuer": "varilleros-api",
